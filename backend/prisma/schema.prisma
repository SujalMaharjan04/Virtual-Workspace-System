generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.

enum Role {
  admin
  employee
}

enum Status {
  offline
  online
}

model User {
  user_id    String   @id @unique @default(uuid())
  name       String
  email      String   @unique @db.VarChar
  password   String
  role       Role     @default(employee)
  status     Status   @default(offline)

  tasksCreated  Task[]  @relation("TaskCreator")
  tasksAssigned Task[]  @relation("TaskAssignee")

  room_members   room_members[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model Room {
  room_id   String  @id 
  room_name String  
  room_password String
  max_capacity  Int @default(10)

  tasks   Task[]
  room_members  room_members[]
}

model Task {
  task_id   String  @id @unique @default(uuid())

  // Link to Room
  room_id   String
  room      Room    @relation( fields: [room_id], references: [room_id])
  
  // Assigned to User
  assigned_to   String
  assignee  User  @relation( "TaskAssignee" , fields: [assigned_to], references: [user_id])

  // Created By User
  created_by  String
  creator User  @relation("TaskCreator", fields: [created_by], references: [user_id])
}

model room_members {
  
  //Link to Room
  room_id String
  room    Room  @relation( fields: [room_id], references: [room_id])

  //Assigned to User
  user_id   String
  user      User    @relation(fields: [user_id], references: [user_id])

  joined_at   DateTime    @default(now())
  is_active   Boolean     @default(false)

  @@id([room_id, user_id])
  @@unique([room_id, user_id])
}
